<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lesson: Hiragana 1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>

        <ImageButton
            android:id="@+id/btnReference"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_book"
            android:contentDescription="Reference"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Set Progress Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SET PROGRESS"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/tvSetProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 / 5 MASTERED"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#00BFA5"
                    android:letterSpacing="0.08"/>
            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBarSet"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:progressDrawable="@drawable/progress_fill"
                android:background="@drawable/progress_track"
                android:max="100"
                android:progress="40"/>

            <!-- Character Strip -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Character 1 -->
                    <LinearLayout
                        android:id="@+id/stripItem1"
                        android:layout_width="68dp"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/char_strip_active"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/stripChar1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="あ"
                            android:textSize="28sp"
                            android:textColor="#6B3EFF"/>
                        <TextView
                            android:id="@+id/stripRomaji1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A"
                            android:textSize="11sp"
                            android:textColor="#6B3EFF"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Character 2 -->
                    <LinearLayout
                        android:id="@+id/stripItem2"
                        android:layout_width="68dp"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/char_strip_inactive"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/stripChar2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="い"
                            android:textSize="28sp"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:id="@+id/stripRomaji2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="I"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- Character 3 -->
                    <LinearLayout
                        android:id="@+id/stripItem3"
                        android:layout_width="68dp"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/char_strip_inactive"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/stripChar3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="う"
                            android:textSize="28sp"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:id="@+id/stripRomaji3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="U"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- Character 4 -->
                    <LinearLayout
                        android:id="@+id/stripItem4"
                        android:layout_width="68dp"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/char_strip_inactive"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/stripChar4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="え"
                            android:textSize="28sp"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:id="@+id/stripRomaji4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="E"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- Character 5 -->
                    <LinearLayout
                        android:id="@+id/stripItem5"
                        android:layout_width="68dp"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/char_strip_inactive">
                        <TextView
                            android:id="@+id/stripChar5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="お"
                            android:textSize="28sp"
                            android:textColor="#1A1A2E"/>
                        <TextView
                            android:id="@+id/stripRomaji5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="O"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Main Character Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/focus_card_background"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 1"
                    android:textSize="12sp"
                    android:textColor="#6B3EFF"
                    android:background="@drawable/level_pill"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvMainCharacter"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:text="あ"
                    android:textSize="100sp"
                    android:textColor="#6B3EFF"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnListen"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="  Listen Pronunciation"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary"
                    android:drawableStart="@drawable/ic_volume"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvSoundsLike"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text='Sounds like: "a" as in Father'
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Memory Hack Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/memory_card_background"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:padding="16dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_lightbulb"
                    android:background="@drawable/memory_icon_bg"
                    android:padding="6dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Memory Hack"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMORY HACK"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#B8860B"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvMemoryTip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="It looks like a big &quot;A&quot; inside a circle!"
                        android:textSize="13sp"
                        android:textColor="#555555"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Usage Example Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/lesson_card_background"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/usage_thumb_background"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_language"
                        android:contentDescription="Word"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvExampleWord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="あき"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:id="@+id/tvExampleRomanization"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AKI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.08"/>
                    <TextView
                        android:id="@+id/tvExampleMeaning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Autumn"
                        android:textSize="13sp"
                        android:textColor="#555555"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnPlayUsage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_volume"
                    android:contentDescription="Play"/>
            </LinearLayout>

            <!-- Reward Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/reward_card_background"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp">
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_badge"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Badge"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPCOMING REWARD"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#00BFA5"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&quot;Kana Novice&quot; Badge at 100%"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp">
        <Button
            android:id="@+id/btnTraceChar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Test"
            android:textSize="15sp"
            android:textColor="#1A1A2E"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="12dp"/>
        <Button
            android:id="@+id/btnNextChar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Next Character →"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"/>
    </LinearLayout>

</LinearLayout>