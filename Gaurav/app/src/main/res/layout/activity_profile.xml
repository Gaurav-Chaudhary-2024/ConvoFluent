<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Profile Header Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp">

                <!-- Avatar + Level Badge -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_person"
                        android:background="@drawable/avatar_background"
                        android:padding="8dp"
                        android:contentDescription="Profile Photo"
                        android:layout_gravity="top|center_horizontal"/>

                    <TextView
                        android:id="@+id/tvLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 14"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/level_badge_profile"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_gravity="bottom|center_horizontal"/>
                </FrameLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sarah Jenkins"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp"/>

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvProfileSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learning Japanese &amp; French"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="20dp"/>

                <!-- XP Progress -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="XP PROGRESS"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvXpProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2,450 / 3,000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#6B3EFF"/>
                </LinearLayout>

                <!-- Progress Bar Fix -->
                <ProgressBar
                    android:id="@+id/pbXp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressDrawable="@drawable/progress_fill"
                    android:background="@drawable/progress_track"
                    android:max="100"
                    android:progress="82"/>

            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <!-- Streak -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_streak"
                        android:background="@drawable/stat_icon_bg_orange"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Streak"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvStreakValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 Days"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STREAK"
                            android:textSize="10sp"
                            android:textColor="#AAAAAA"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#EEEEEE"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>

                <!-- Ranking -->
                <LinearLayout
                    android:id="@+id/statRanking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_trophy"
                        android:background="@drawable/stat_icon_bg_purple"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Ranking"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRankingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Top 5%"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RANKING"
                            android:textSize="10sp"
                            android:textColor="#AAAAAA"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- My Interests Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="My Interests"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All  ›"
                        android:textSize="13sp"
                        android:textColor="#6B3EFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Row 1 — Active chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📺 Anime"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/chip_active"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✈ Travel"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/chip_active"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮 Gaming"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/chip_active"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"/>
                </LinearLayout>

                <!-- Row 2 — Inactive chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍴 Food"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:background="@drawable/chip_inactive"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎵 Music"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:background="@drawable/chip_inactive"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷 Photography"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:background="@drawable/chip_inactive"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your feed updates automatically based on these topics to keep your lessons engaging."
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Current Milestones Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Milestones"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="20dp"/>

                <!-- Milestone 1 - Word Smith -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_xp"
                            android:background="@drawable/milestone_icon_bg_teal"
                            android:padding="10dp"
                            android:layout_marginEnd="14dp"
                            android:contentDescription="Word Smith"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Word Smith"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A2E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Learn 500 new words"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="6dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:background="@drawable/progress_track"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:weightSum="1">
                            <View
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="0.85"
                                android:background="@drawable/progress_fill"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Milestone 2 - Daily Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_streak"
                            android:background="@drawable/milestone_icon_bg_orange"
                            android:padding="10dp"
                            android:layout_marginEnd="14dp"
                            android:contentDescription="Daily Legend"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Daily Legend"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A2E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="30 day streak"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="6dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:background="@drawable/progress_track"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:weightSum="1">
                            <View
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="0.40"
                                android:background="@drawable/progress_fill"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Milestone 3 - Social Butterfly -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_sparkle"
                            android:background="@drawable/milestone_icon_bg_purple"
                            android:padding="10dp"
                            android:layout_marginEnd="14dp"
                            android:contentDescription="Social Butterfly"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Social Butterfly"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A2E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10 AI conversations"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="6dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:background="@drawable/progress_track"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:weightSum="1">
                            <View
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1.0"
                                android:background="@drawable/progress_fill"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Learning Preferences Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learning Preferences"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="16dp"/>

                <!-- Daily Goal Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/pref_row_background"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Goal"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>

                        <TextView
                            android:id="@+id/tvDailyGoalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15 minutes / day"
                            android:textSize="12sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnChangeDailyGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Change"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:background="@drawable/pref_button_bg"/>
                </LinearLayout>

                <!-- Difficulty Level Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/pref_row_background"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Difficulty Level"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>

                        <TextView
                            android:id="@+id/tvDifficultyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Intermediate (B1)"
                            android:textSize="12sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAdjustDifficulty"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Adjust"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:background="@drawable/pref_button_bg"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabLessons"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_lessons"
                android:contentDescription="Lessons"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lessons"
                android:textSize="11sp"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabAlphabet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_alphabet"
                android:contentDescription="Alphabet"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alphabet"
                android:textSize="11sp"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Profile"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="#6B3EFF"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>