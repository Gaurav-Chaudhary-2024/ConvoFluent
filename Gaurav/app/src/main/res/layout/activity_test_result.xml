<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test Results"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"/>

        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_info"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Info"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mastery Card (purple gradient header) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/result_header_bg"
                android:padding="20dp"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <!-- Mastery Achieved label -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/result_mastery_chip_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="5dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MASTERY ACHIEVED"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.08"/>
                </LinearLayout>

                <!-- Percentage -->
                <TextView
                    android:id="@+id/tvMasteryPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="82%"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvMasterySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Great Job, Alex! You're getting closer to B2 Fluency."
                    android:textSize="13sp"
                    android:textColor="#DDD6FF"
                    android:gravity="center"
                    android:layout_marginBottom="20dp"/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- XP Earned -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/result_stat_chip_bg"
                        android:padding="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡"
                            android:textSize="18sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="XP EARNED"
                            android:textSize="10sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvXpEarned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+450"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                    <!-- Grade -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/result_stat_chip_bg"
                        android:padding="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎓"
                            android:textSize="18sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GRADE"
                            android:textSize="10sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvGrade"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A-"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                    <!-- Lifetime Stats -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/result_stat_chip_bg"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="18sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL"
                            android:textSize="10sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvTestCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- tests"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- SKILL BREAKDOWN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SKILL BREAKDOWN"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:letterSpacing="0.06"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <!-- Listening -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LISTENING" android:textSize="10sp" android:textColor="#888888" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvListeningPct" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="–%" android:textSize="16sp"
                        android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <View android:layout_width="match_parent" android:layout_height="3dp"
                        android:background="#6B3EFF" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Speaking -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SPEAKING" android:textSize="10sp" android:textColor="#888888" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvSpeakingPct" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="–%" android:textSize="16sp"
                        android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <View android:layout_width="match_parent" android:layout_height="3dp"
                        android:background="#6B3EFF" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Reading -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="READING" android:textSize="10sp" android:textColor="#888888" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvReadingPct" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="–%" android:textSize="16sp"
                        android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <View android:layout_width="match_parent" android:layout_height="3dp"
                        android:background="#6B3EFF" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Writing/Grammar -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GRAMMAR" android:textSize="10sp" android:textColor="#888888" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvWritingPct" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="–%" android:textSize="16sp"
                        android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <View android:layout_width="match_parent" android:layout_height="3dp"
                        android:background="#DDDDDD" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- DETAILED ANALYSIS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DETAILED ANALYSIS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" android:letterSpacing="0.06"/>

                <TextView
                    android:id="@+id/tvShowingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Showing 10 Questions"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Dynamic question cards injected here -->
            <LinearLayout
                android:id="@+id/detailContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

            <!-- Focus on Pronunciation banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/result_focus_banner_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/result_focus_icon_bg"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💬" android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Focus on Pronunciation"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="You missed 2 speaking tasks. Practice your vowels to improve!"
                        android:textSize="12sp" android:textColor="#555555"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Performance Insight banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/result_insight_banner_bg"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚡" android:textSize="18sp" android:layout_marginEnd="10dp"/>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Performance Insight — Improve &quot;Speaking&quot; score by 15%"
                android:textSize="13sp" android:textColor="#6B3EFF"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Quick Practice"
                    android:textSize="12sp" android:textStyle="bold" android:textColor="#6B3EFF"
                    android:background="@drawable/result_quick_practice_bg"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Share / Retake row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:id="@+id/btnShare"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_outline"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginEnd="10dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⇧  Share Result"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnRetake"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_outline"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↺  Retake Test"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Review Mistakes CTA -->
            <LinearLayout
                android:id="@+id/btnReviewMistakes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/btn_primary"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Review Mistakes  →"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>