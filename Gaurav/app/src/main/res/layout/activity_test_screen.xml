<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginStart="8dp"/>

        <!-- Timer Pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/timer_pill_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_time"
                android:layout_marginEnd="5dp"
                android:contentDescription="Timer"/>

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04:59"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#6B3EFF"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvQuestionCounter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Question 1 of 10"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score: 0 pts"
                    android:textSize="13sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progress="0"
                android:progressDrawable="@drawable/progress_fill"
                android:background="@drawable/progress_track"
                android:layout_marginBottom="16dp"/>

            <!-- Question Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/question_card_bg"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Type chip + Points row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tvQuestionType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listening"
                        android:textSize="12sp"
                        android:textColor="#6B3EFF"
                        android:background="@drawable/listening_chip_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_info"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="Info"/>

                    <TextView
                        android:id="@+id/tvQuestionPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Point: 100"
                        android:textSize="13sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <!-- Audio Player Row (visible only for Listening questions) -->
                <LinearLayout
                    android:id="@+id/audioPlayerRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:visibility="visible">

                    <LinearLayout
                        android:id="@+id/btnPlay"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/play_btn_circle"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_play"
                            android:contentDescription="Play"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginEnd="8dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/progress_track"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:12"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>

                    <ImageButton
                        android:id="@+id/btnReplay"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_replay"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Replay"/>
                </LinearLayout>

                <!-- Question Text -->
                <TextView
                    android:id="@+id/tvQuestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvQuestionSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"/>
            </LinearLayout>

            <!-- Option A -->
            <LinearLayout
                android:id="@+id/optionA"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/option_default_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:background="@drawable/option_letter_bg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp"/>

                <TextView
                    android:id="@+id/tvOptionA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"/>
            </LinearLayout>

            <!-- Option B -->
            <LinearLayout
                android:id="@+id/optionB"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/option_default_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:background="@drawable/option_letter_bg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp"/>

                <TextView
                    android:id="@+id/tvOptionB"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"/>
            </LinearLayout>

            <!-- Option C -->
            <LinearLayout
                android:id="@+id/optionC"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/option_default_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="C"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:background="@drawable/option_letter_bg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp"/>

                <TextView
                    android:id="@+id/tvOptionC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"/>
            </LinearLayout>

            <!-- Option D -->
            <LinearLayout
                android:id="@+id/optionD"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/option_default_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="D"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:background="@drawable/option_letter_bg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp"/>

                <TextView
                    android:id="@+id/tvOptionD"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"/>
            </LinearLayout>

            <!-- Bottom Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/btnSkip"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_outline"
                    android:gravity="center"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skip"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCheckAnswer"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="2"
                    android:background="@drawable/btn_check_disabled"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCheckAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check Answer"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#AAAAAA"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Report an issue -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_info"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="Report"/>

                <TextView
                    android:id="@+id/tvReportIssue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report an issue  ›"
                    android:textSize="13sp"
                    android:textColor="#888888"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>