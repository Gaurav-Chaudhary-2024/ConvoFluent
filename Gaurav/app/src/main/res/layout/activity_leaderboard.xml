                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18,920 XP"
                        android:textSize="11sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <!-- Rank 3 -->
                <LinearLayout
