                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progress="81"
                        android:progressDrawable="@drawable/progress_fill"
                        android:background="@drawable/progress_track"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="2dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvMyXp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="4,850 XP"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6,000 XP"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout><!-- end leaderboardContainer -->

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"/>

        <!-- Bottom Sticky Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="12dp">

            <!-- Your Ranking Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/avatar_background"
                    android:contentDescription="Your avatar"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tvMyUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Ranking"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:id="@+id/tvMyXpToNext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="124 XP to reach Rank #11"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvMyRank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#12"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#6B3EFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOP 2%"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#888888"/>
                </LinearLayout>
            </LinearLayout>

            <!-- My Statistics Button Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/btnMyStatistics"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_primary"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Statistics  ↗"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/more_btn_bg"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="···"
                        android:textSize="18sp"
                        android:textColor="#1A1A2E"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>