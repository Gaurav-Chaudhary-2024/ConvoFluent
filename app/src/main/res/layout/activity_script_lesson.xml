<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/text_secondary"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Lesson: Hiragana I"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"/>

        <ImageButton
            android:id="@+id/btnBookmark"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmark_border"
            android:tint="@color/text_muted"
            android:contentDescription="Bookmark"/>
    </LinearLayout>

    <!-- Progress: 2 of 5 mastered -->
    <LinearLayout
        android:id="@+id/layoutProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SET PROGRESS"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.08"
            android:layout_marginEnd="10dp"/>

        <ProgressBar
            android:id="@+id/progressLesson"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:progressDrawable="@drawable/bg_progress_fill"
            android:progress="40"
            android:max="100"/>

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 / 5 MASTERED"
            android:textColor="@color/purple_light"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <!-- ── CHARACTER STRIP (horizontal row) ── -->
    <HorizontalScrollView
        android:id="@+id/charStripScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/layoutProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/llCharStrip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Char tile あ - mastered -->
            <LinearLayout
                android:id="@+id/tileA"
                android:layout_width="64dp"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_char_selected"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="@color/purple_primary"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="あ"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- い mastered -->
            <LinearLayout
                android:id="@+id/tileI"
                android:layout_width="64dp"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_char_selected"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="@color/purple_primary"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="い"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- う current -->
            <LinearLayout
                android:id="@+id/tileU"
                android:layout_width="64dp"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_char_card"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="う"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="U"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- え -->
            <LinearLayout
                android:id="@+id/tileE"
                android:layout_width="64dp"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_char_card">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="え"
                    android:textColor="@color/text_secondary"
                    android:textSize="22sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── MAIN SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/charStripScroll"
        app:layout_constraintBottom_toTopOf="@id/bottomButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Big character display card -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_card_surface">

                <!-- Level badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|top"
                    android:layout_margin="12dp"
                    android:text="Level 1"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_level_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <!-- Main hiragana character -->
                <TextView
                    android:id="@+id/tvMainChar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="あ"
                    android:textColor="@color/text_primary"
                    android:textSize="80sp"
                    android:fontFamily="sans-serif"/>
            </FrameLayout>

            <!-- Listen Pronunciation button -->
            <Button
                android:id="@+id/btnListen"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="🔊  Listen Pronunciation"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_continue_btn"
                android:stateListAnimator="@null"/>

            <TextView
                android:id="@+id/tvSoundsLike"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Sounds like 'a' as in Father"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:gravity="center"/>

            <!-- Memory Hack card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_memory_hack"
                android:padding="14dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMORY HACK"
                        android:textColor="@color/accent_amber"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvMemoryHack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="It looks like a big 'A' inside a circle!"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Usage Example card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_usage_example"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️  USAGE EXAMPLE"
                    android:textColor="@color/purple_light"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.08"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <!-- Character box -->
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_ai_avatar"
                        android:layout_marginEnd="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="あ"
                            android:textColor="@color/text_primary"
                            android:textSize="28sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvExampleKanji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="あき"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:id="@+id/tvExampleMeaning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AKI\nAutumn"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnExampleSound"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_volume_up"
                        android:tint="@color/text_muted"
                        android:contentDescription="Play example"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Unlock Rewards banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_unlock_reward"
                android:padding="14dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="UNLOCK REWARDS\n\&quot;Kana Novice\&quot; Badge at 100%"
                    android:textColor="@color/purple_light"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- bottom padding -->
            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BOTTOM BUTTONS ── -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_dark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnTraceChar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="Trace Char"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_outline_btn"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnNextChar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Next Character →"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_continue_btn"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>