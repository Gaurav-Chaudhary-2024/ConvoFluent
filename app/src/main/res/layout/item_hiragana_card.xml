<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_char_card"
    android:padding="14dp"
    android:layout_margin="5dp">

    <!-- Hiragana character -->
    <TextView
        android:id="@+id/tvHiragana"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="36sp"
        android:fontFamily="sans-serif"/>

    <!-- Romaji -->
    <TextView
        android:id="@+id/tvRomaji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/purple_light"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"/>

    <!-- Hint description -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.4"/>

    <!-- Sound icon -->
    <ImageView
        android:id="@+id/ivSound"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_volume_up"
        android:tint="@color/text_muted"
        android:contentDescription="Play sound"/>

    <!-- Blue dot indicator (mastered) -->
    <View
        android:id="@+id/dotMastered"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="end"
        android:background="@drawable/dot_blue"
        android:visibility="gone"/>
</LinearLayout>